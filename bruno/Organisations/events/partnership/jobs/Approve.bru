  body: none
  auth: none
}

params:path {
  promotion_id: 
  partnership_id: {{partnership_id}}
  org_slug: {{org_slug}}
  event_slug: {{event_slug}}
}

headers {
  Authorization: Bearer {{token}}
}

body:json {
  {
    "subject": "Test",
    "body": "Test"
  }
}
